{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Battlechain Docs",
  "colors": {
    "primary": "#FFFFFF",
    "light": "#FFFFFF",
    "dark": "#CCCCCC"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://cyfrin.io"
  },
  "navbar": {
    "links": [
      {
        "label": "Community",
        "href": "https://discord.gg/cyfrin"
      },
      {
        "label": "GitHub",
        "href": "https://github.com/Cyfrin/docs-battlechain"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Sign In",
      "href": "https://profiles.cyfrin.io"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "dropdowns": [
          {
            "dropdown": "Battlechain",
            "icon": "/images/product-logos/battlechain.svg",
            "pages": [
              "overview",
              {
                "divider": true
              },
              {
                "group": "Quickstart",
                "pages": [
                  "battlechain/quickstart/deploy-your-contract",
                  "battlechain/quickstart/configure-ai-tools"
                ]
              },
              {
                "group": "Tutorials",
                "pages": [
                  "battlechain/tutorials/going-attackable",
                  "battlechain/tutorials/deploying-contracts",
                  "battlechain/tutorials/attacking-contracts",
                  "battlechain/tutorials/approving-requests",
                  "battlechain/tutorials/prediction-market"
                ]
              },
              {
                "group": "How-to Guides",
                "pages": [
                  "battlechain/how-to/use-ai-with-docs",
                  "battlechain/how-to/add-battlechain-to-metamask",
                  {
                    "group": "Block Explorer",
                    "pages": [
                      "battlechain/how-to/exploring-agreements",
                      "battlechain/how-to/managing-agreements-in-explorer",
                      "battlechain/how-to/verifying-contracts"
                    ]
                  },
                  {
                    "group": "For Protocols",
                    "pages": [
                      "battlechain/how-to/create-agreement",
                      "battlechain/how-to/request-attack-mode",
                      "battlechain/how-to/promote-to-production"
                    ]
                  },
                  {
                    "group": "For Whitehats",
                    "pages": [
                      "battlechain/how-to/find-attackable-contracts",
                      "battlechain/how-to/execute-attack",
                      "battlechain/how-to/claim-bounties"
                    ]
                  },
                  {
                    "group": "For the DAO",
                    "pages": [
                      "battlechain/how-to/approve-reject-requests",
                      "battlechain/how-to/instant-promotion",
                      "battlechain/quickstart/review-first-request"
                    ]
                  }
                ]
              },
              {
                "group": "Reference",
                "pages": [
                  "battlechain/reference/contracts",
                  "battlechain/reference/mock-contracts",
                  "battlechain/reference/contract-states",
                  "battlechain/reference/bounty-terms",
                  "battlechain/reference/identity-requirements",
                  "battlechain/reference/governance-parameters"
                ]
              },
              {
                "divider": true
              },
              "battlechain/explanation/contract-lifecycle",
              "battlechain/explanation/safe-harbor",
              "battlechain/explanation/best-practices"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Battlechain",
          "href": "https://battlechain.cyfrin.io",
          "icon": "gamepad"
        },
        {
          "anchor": "Discord Community",
          "href": "https://discord.gg/cyfrin",
          "icon": "discord"
        }
      ]
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/battlechain",
      "github": "https://github.com/Cyfrin/docs-battlechain",
      "discord": "https://discord.gg/cyfrin",
      "linkedin": "https://linkedin.com/company/cyfrin"
    }
  },
  "styling": {
    "codeblocks": {
      "theme": "github-dark-dimmed"
    }
  },
  "css": [
    "/styles.css",
    "/product-themes.css"
  ]
}